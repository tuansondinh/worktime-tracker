#!/bin/bash
STATE_DIR=~/.worktime
TODAY=$(date +%Y-%m-%d)

# Route subcommands
case "${1:-}" in
  stats)
    shift
    exec "$HOME/.worktime/stats.sh" "$@"
    ;;
  config)
    shift
    CONFIG_FILE="$STATE_DIR/config.json"

    # Load current config values (defaults if file missing or field absent)
    _cfg_break_notif="true"
    _cfg_sound="true"
    _cfg_break_threshold=60
    _cfg_daily_limit=480
    if [ -f "$CONFIG_FILE" ]; then
      _v=$(grep -o '"enable_break_notifications": *\(true\|false\)' "$CONFIG_FILE" | grep -o '\(true\|false\)')
      [ -n "$_v" ] && _cfg_break_notif="$_v"
      _v=$(grep -o '"enable_notification_sound": *\(true\|false\)' "$CONFIG_FILE" | grep -o '\(true\|false\)')
      [ -n "$_v" ] && _cfg_sound="$_v"
      _v=$(grep -o '"break_threshold": *[0-9]*' "$CONFIG_FILE" | grep -o '[0-9]*')
      [ -n "$_v" ] && _cfg_break_threshold="$_v"
      _v=$(grep -o '"daily_limit": *[0-9]*' "$CONFIG_FILE" | grep -o '[0-9]*')
      [ -n "$_v" ] && _cfg_daily_limit="$_v"
    fi

    # Write full config with all fields
    write_config() {
      mkdir -p "$STATE_DIR"
      printf '{"enable_break_notifications": %s, "enable_notification_sound": %s, "break_threshold": %s, "daily_limit": %s}\n' \
        "$_cfg_break_notif" "$_cfg_sound" "$_cfg_break_threshold" "$_cfg_daily_limit" > "$CONFIG_FILE"
    }

    case "${1:-}" in
      show|"")
        _limit_h=$(( _cfg_daily_limit / 60 ))
        _limit_m=$(( _cfg_daily_limit % 60 ))
        _limit_str="${_limit_h}h"; [ "$_limit_m" -gt 0 ] && _limit_str="${_limit_h}h ${_limit_m}m"
        if [ -f "$CONFIG_FILE" ]; then
          echo "Settings:"
          [ "$_cfg_break_notif" = "true" ] && echo "  Break notifications: ✓ enabled" || echo "  Break notifications: ✗ disabled"
          [ "$_cfg_sound" = "true" ] && echo "  Notification sound: ✓ enabled" || echo "  Notification sound: ✗ disabled"
          echo "  Break time: ${_cfg_break_threshold} min"
          echo "  Daily limit: ${_limit_str}"
          _sr=$(defaults read com.pilotmoon.scroll-reverser InvertScrollingOn 2>/dev/null || echo "0")
          [ "$_sr" = "1" ] && echo "  Scroll Reverser: ✓ enabled" || echo "  Scroll Reverser: ✗ disabled"
        else
          echo "No config file found. Using defaults:"
          echo "  Break notifications: ✓ enabled"
          echo "  Notification sound: ✓ enabled"
          echo "  Break time: 60 min"
          echo "  Daily limit: 8h"
        fi
        ;;
      break)
        if [ "${2:-}" = "off" ]; then
          _cfg_break_notif="false"; write_config
          echo "✓ Break notifications disabled"
        elif [ "${2:-}" = "on" ]; then
          _cfg_break_notif="true"; write_config
          echo "✓ Break notifications enabled"
        else
          echo "Usage: worktime config break [on|off]"
        fi
        ;;
      sound)
        if [ "${2:-}" = "off" ]; then
          _cfg_sound="false"; write_config
          echo "✓ Notification sound disabled"
        elif [ "${2:-}" = "on" ]; then
          _cfg_sound="true"; write_config
          echo "✓ Notification sound enabled"
        else
          echo "Usage: worktime config sound [on|off]"
        fi
        ;;
      break-time)
        if [ -n "${2:-}" ] && [[ "${2}" =~ ^[0-9]+$ ]]; then
          _cfg_break_threshold="${2}"; write_config
          echo "✓ Break time set to ${2} min"
        else
          echo "Usage: worktime config break-time <minutes>"
          echo "Example: worktime config break-time 45"
        fi
        ;;
      limit)
        if [ -n "${2:-}" ] && [[ "${2}" =~ ^[0-9]+$ ]]; then
          _cfg_daily_limit="${2}"; write_config
          _lh=$(( ${2} / 60 )); _lm=$(( ${2} % 60 ))
          _ls="${_lh}h"; [ "$_lm" -gt 0 ] && _ls="${_lh}h ${_lm}m"
          echo "✓ Daily limit set to ${_ls} (warning at $(( ${2} - 60 )) min)"
        else
          echo "Usage: worktime config limit <minutes>"
          echo "Example: worktime config limit 360   # 6 hours"
        fi
        ;;
      scroll)
        if [ "${2:-}" = "off" ]; then
          defaults write com.pilotmoon.scroll-reverser InvertScrollingOn -bool false
          echo "✓ Scroll Reverser disabled"
        elif [ "${2:-}" = "on" ]; then
          defaults write com.pilotmoon.scroll-reverser InvertScrollingOn -bool true
          echo "✓ Scroll Reverser enabled"
        else
          echo "Usage: worktime config scroll [on|off]"
        fi
        ;;
      *)
        echo "Usage: worktime config [show|break|sound|break-time|limit|scroll] [value]"
        echo ""
        echo "Examples:"
        echo "  worktime config show              # Show current settings"
        echo "  worktime config break off         # Disable break notifications"
        echo "  worktime config sound off         # Disable notification sound"
        echo "  worktime config break-time 45     # Set break interval to 45 min"
        echo "  worktime config limit 360         # Set daily limit to 6h"
        echo "  worktime config scroll off        # Disable auto scroll sync"
        ;;
    esac
    exit 0
    ;;
  --help|-h|"help")
    echo "Usage: worktime [command] [options]"
    echo ""
    echo "Commands:"
    echo "  (default)    Show today's active time"
    echo "  stats        Show usage statistics"
    echo "  config       Manage notifications and settings"
    echo ""
    echo "Options (default command):"
    echo "  --verbose    Show detailed status"
    echo ""
    echo "Options (stats):"
    echo "  --week       This week's stats (default)"
    echo "  --month      This month's stats"
    echo "  --all        All-time stats"
    echo "  --json       Output as JSON"
    echo ""
    echo "Options (config):"
    echo "  show                  Show current settings"
    echo "  break [on|off]        Enable/disable break notifications"
    echo "  sound [on|off]        Enable/disable notification sound"
    echo "  break-time <minutes>  Set break interval (default: 60)"
    echo "  limit <minutes>       Set daily limit (default: 480 = 8h)"
    echo "  scroll [on|off]       Enable/disable auto scroll sync (mouse detection)"
    exit 0
    ;;
esac

STATE_FILE="$STATE_DIR/$TODAY.log"

if [ ! -f "$STATE_FILE" ]; then
  echo "No activity logged for today ($TODAY)"
  exit 1
fi

source "$STATE_FILE"

# Constants (defaults, may be overridden by config)
BREAK_THRESHOLD=60
LIMIT_8H=480
WARNING_7H=420

CONFIG_FILE="$STATE_DIR/config.json"
if [ -f "$CONFIG_FILE" ]; then
  _v=$(grep -o '"break_threshold": *[0-9]*' "$CONFIG_FILE" | grep -o '[0-9]*')
  [ -n "$_v" ] && BREAK_THRESHOLD=$_v
  _v=$(grep -o '"daily_limit": *[0-9]*' "$CONFIG_FILE" | grep -o '[0-9]*')
  if [ -n "$_v" ]; then
    LIMIT_8H=$_v
    WARNING_7H=$(( LIMIT_8H - 60 ))
  fi
fi

# Calculate time until next break and remaining
if [ $active_minutes -ge $LIMIT_8H ]; then
  remaining="0 min"
  next_break="Limit reached"
elif [ $active_minutes -ge $WARNING_7H ]; then
  remaining=$((LIMIT_8H - active_minutes))
  next_break="Limit"
else
  remaining=$((BREAK_THRESHOLD - active_minutes))
  next_break="$BREAK_THRESHOLD min"
fi

# Format active time
hours=$((active_minutes / 60))
mins=$((active_minutes % 60))
active_str="${hours}h ${mins}m"

# Print status
if [ "$VERBOSE" = "true" ] || [ "$1" = "--verbose" ]; then
  echo "Work Time Tracker - $TODAY"
  echo "=========================="
  echo "Active time: $active_str"
  echo ""
  echo "Time to next break: $next_break (at $BREAK_THRESHOLD min)"
  echo "Time to daily limit: $remaining min (at $LIMIT_8H min)"
  echo ""
  echo "Log file: $STATE_FILE"
else
  # Compact format for quick viewing
  echo "⏱ $active_str"
fi
